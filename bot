@client.tree.command(name="keyadd", description="🔑 Asigna una llave a un usuario")
async def keyadd(interaction: discord.Interaction, usuario: discord.Member):
    if not is_admin(interaction): return
    role = discord.utils.get(interaction.guild.roles, name="🔑Key")
    if not role:
        try: role = await interaction.guild.create_role(name="🔑Key", color=discord.Color.from_rgb(0, 0, 0))
        except: pass
    try:
        if role: await usuario.add_roles(role)
        await interaction.response.send_message(f"✅ Llave asignada a {usuario.mention}")
    except: await interaction.response.send_message("❌ Error al asignar rol.", ephemeral=True)

@client.tree.command(name="keycreate", description="🔑 Crea una llave para el servidor")
async def keycreate(interaction: discord.Interaction, key: str):
    if not is_admin(interaction): return
    server_keys[interaction.guild_id] = key
    await interaction.response.send_message(f"✅ Key `{key}` creada.")

@client.tree.command(name="keyremove", description="🔑 Remueve la llave de un usuario")
async def keyremove(interaction: discord.Interaction, usuario: discord.Member):
    if not is_admin(interaction): return
    role = discord.utils.get(interaction.guild.roles, name="🔑Key")
    if role:
        try:
            await usuario.remove_roles(role)
            await interaction.response.send_message(f"✅ Llave removida de {usuario.mention}")
        except: await interaction.response.send_message("❌ Error.", ephemeral=True)
    else: await interaction.response.send_message("❌ El rol no existe.", ephemeral=True)

