class RaidEliminarView(ui.View):
    def __init__(self, interaction: discord.Interaction):
        super().__init__(timeout=60)
        self.interaction = interaction
        self.selected_option = None

    @ui.select(
        placeholder="🛠 Elija una opción de limpieza",
        options=[
            discord.SelectOption(label="Eliminar canales", value="canales", description="Elimina canales creados durante el raid", emoji="🗑️"),
            discord.SelectOption(label="Eliminar roles", value="roles", description="Elimina roles creados recientemente", emoji="🎭"),
            discord.SelectOption(label="Eliminar bot de raid", value="bot", description="Expulsa/Banea al bot atacante", emoji="🤖"),
        ]
    )
    async def select_callback(self, interaction: discord.Interaction, select: ui.Select):
        if interaction.user.id != self.interaction.user.id:
            return await interaction.response.send_message("❌ No puedes usar este menú.", ephemeral=True)
        self.selected_option = select.values[0]
        await interaction.response.defer()

    @ui.button(label="Confirmar", style=discord.ButtonStyle.green, emoji="✅")
    async def confirm(self, interaction: discord.Interaction, button: ui.Button):
        if interaction.user.id != self.interaction.user.id:
            return await interaction.response.send_message("❌ No puedes usar este botón.", ephemeral=True)
        
        if not self.selected_option:
            embed = discord.Embed(
                title="<a:alertaanimado:1472301990792134848> Acción No Seleccionada",
                description="No seleccionaste ninguna opción del menú.\n\n<a:flechaanimada:1472301988124430499> Debes elegir una opción antes de confirmar.\nEl proceso fue cancelado automáticamente.",
                color=discord.Color.red()
            )
            return await interaction.response.edit_message(embed=embed, view=None)

        if not interaction.guild.me.guild_permissions.administrator:
            embed = discord.Embed(
                title="<a:exanimado:1472301942683209788> Error de Permisos",
                description="<a:alertaanimado:1472301990792134848> No tengo permisos suficientes para ejecutar esta acción.\n\n🔎 Posibles razones:\n• Mi rol está debajo del objetivo.\n• No tengo permisos de administrador.\n• No tengo permisos para gestionar canales o roles.\n\n⬆️ Sube mi rol más arriba y vuelve a intentarlo.",
                color=discord.Color.red()
            )
            return await interaction.response.edit_message(embed=embed, view=None)

        guild = interaction.guild
        user = interaction.user

        if self.selected_option == "canales":
            deleted = 0
            for channel in list(guild.channels):
                if channel.name not in PROTECTED_CHANNELS:
                    try:
                        await channel.delete(reason="Eliminar Raid")
                        deleted += 1
                    except: pass
            
            embed = discord.Embed(
                title="<a:marcadeverificacionanim:1472301965072662538> Eliminación Completada",
                description=f"<a:fuegoanimado:1472301940389183488> Los canales sospechosos fueron eliminados correctamente.\n<a:llamaanimada:1472301937042002105> El servidor está nuevamente bajo control.\n\n📊 Resultado:\n• 🗑️ Canales eliminados: {deleted}\n• 👤 Acción ejecutada por: {user.mention}",
                color=discord.Color.green()
            )
            await interaction.response.edit_message(embed=embed, view=None)
            
            try:
                report_ch = await guild.create_text_channel("raid-terminada")
                report_embed = discord.Embed(
                    description="<a:Fuegomorado:1472301996164780052> Se detectó actividad sospechosa en el servidor.\n\n<a:flechaanimada:1472301988124430499> Sistema de protección activado\n<a:across9:1472301994365423861> Amenaza neutralizada\n<a:across9:1472301994365423861> Integridad del servidor asegurada\n\nNyxGuard respondió automáticamente y evitó daños.",
                    color=discord.Color.purple()
                )
                await report_ch.send(embed=report_embed)
            except: pass

        elif self.selected_option == "roles":
            deleted = 0
            for role in list(guild.roles):
                if role.name not in PROTECTED_ROLES and not role.managed and role < guild.me.top_role and role != guild.default_role:
                    try:
                        await role.delete(reason="Eliminar Raid")
                        deleted += 1
                    except: pass
            
            embed = discord.Embed(
                title="<a:marcadeverificacionanim:1472301965072662538> Roles Eliminados",
                description=f"<a:diamantebanimado:1472301950023504133> Roles sospechosos eliminados correctamente.\n<a:azulhypeinfanimado:1472301985318568117> Permisos peligrosos removidos.\n\n📊 Resultado:\n• 🎭 Roles eliminados: {deleted}\n• 👤 Ejecutado por: {user.mention}",
                color=discord.Color.green()
            )
            await interaction.response.edit_message(embed=embed, view=None)

        elif self.selected_option == "bot":
            found = False
            async for member in guild.fetch_members(limit=None):
                if member.bot and member.id != interaction.client.user.id and member.guild_permissions.administrator:
                    try:
                        await member.ban(reason="Bot de Raid detectado")
                        found = True
                    except: pass
            
            if found:
                embed = discord.Embed(
                    title="<a:marcadeverificacionanim:1472301965072662538> Bot Malicioso Eliminado",
                    description="<a:banhammer9animado:1472301982932013349> El bot de raid fue expulsado/baneado correctamente.\n<a:flechaanimada:1472301988124430499> Acceso bloqueado al sistema malicioso.\n\n🛡️ Seguridad restaurada.",
                    color=discord.Color.green()
                )
            else:
                embed = discord.Embed(description="No se detectó ningún bot malicioso con permisos administrativos.", color=discord.Color.red())
            
            await interaction.response.edit_message(embed=embed, view=None)

    @ui.button(label="Cancelar", style=discord.ButtonStyle.red, emoji="✖️")
    async def cancel(self, interaction: discord.Interaction, button: ui.Button):
        if interaction.user.id != self.interaction.user.id:
            return await interaction.response.send_message("❌ No puedes usar este botón.", ephemeral=True)
        
        embed = discord.Embed(
            title="<a:exanimado:1472301942683209788> Operación Cancelada",
            description="La eliminación fue cancelada correctamente.\n\n<a:PruebaFLanimada:1472301938942017577> No se realizaron cambios en el servidor.",
            color=discord.Color.red()
        )
        await interaction.response.edit_message(embed=embed, view=None)

class MyClient(discord.Client):
    def __init__(self):
        # Desactivamos intents privilegiados para permitir que el bot encienda
        # incluso si el usuario no los ha activado en el portal.
        intents = discord.Intents.default()
        intents.guilds = True
        # NO activamos members ni message_content aquí para evitar el error de Shard ID None
        super().__init__(intents=intents)
        self.tree = app_commands.CommandTree(self)

    async def setup_hook(self):
        await self.tree.sync()

client = MyClient()

def is_admin(interaction: discord.Interaction):
    return interaction.user.guild_permissions.administrator or interaction.user.id == OWNER_ID

# --- EVENTOS ---
@client.event
async def on_message(message):
    if message.author.bot: return
    # Nota: Requiere Message Content Intent para detectar @everyone
    if security_systems.get("antiflood") and "@everyone" in message.content:
        if message.channel.name not in PROTECTED_CHANNELS:
            try: await message.delete()
            except: pass

@client.event
async def on_guild_channel_create(channel):
    if security_systems.get("antiraid"):
        if channel.name not in PROTECTED_CHANNELS:
            try: await channel.delete(reason="Anti-Raid: Detección automática")
            except: pass

